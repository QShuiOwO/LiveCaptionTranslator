# LiveCaptionTranslator .gitignore

# Visual Studio / Rider
.vs/
.idea/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.DotSettings.user
*.ncrunch*
*.VisualState.xml

# .NET / WPF build output
[Bb]in/
[Oo]bj/
publish/
artifacts/
TestResults/
coverage/
coverage*/
*.coverage
*.coveragexml
*.trx
*.nupkg
*.snupkg
*.pdb

# Runtime logs and local diagnostics
logs/
**/logs/
*.log
*.dmp

# Python cache / virtual environments
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.ipynb_checkpoints/
.cache/
.venv/
venv/
env/
.env
.env.*

# Local NLLB / model files
# Keep worker code, tokenizer metadata, and small CT2 metadata tracked.
# Do not commit large model weights; GitHub rejects normal blobs over 100MB.
tools/nllb/models/
tools/nllb/checkpoints/
tools/nllb/cache/
tools/nllb/**/cache/
tools/nllb/**/.huggingface/
tools/nllb/**/.hf/
tools/nllb/*.bin
tools/nllb/*.pt
tools/nllb/*.pth
tools/nllb/*.safetensors
tools/nllb/*.onnx
tools/nllb/*.onnx_data
tools/nllb/*.spm
tools/nllb/*.ckpt
tools/nllb/*.npy
tools/nllb/*.npz
tools/nllb/*.h5
tools/nllb/*.pb
tools/nllb/*.tflite
tools/nllb/*.msgpack
tools/nllb/**/*.bin
tools/nllb/**/*.pt
tools/nllb/**/*.pth
tools/nllb/**/*.safetensors
tools/nllb/**/*.onnx
tools/nllb/**/*.onnx_data
tools/nllb/**/*.spm
tools/nllb/**/*.ckpt
tools/nllb/**/*.npy
tools/nllb/**/*.npz
tools/nllb/**/*.h5
tools/nllb/**/*.pb
tools/nllb/**/*.tflite
tools/nllb/**/*.msgpack
tools/nllb/**/pytorch_model*
tools/nllb/**/tf_model*
tools/nllb/**/flax_model*
tools/nllb/**/.cache/
!tools/nllb/**/.gitkeep
!tools/nllb/**/*.json

# Local config and secrets
appsettings.Development.json
appsettings.Local.json
*.local.json
*.secret.json

# OS files
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Temporary files
*.tmp
*.bak
*.orig
*.rej
*.patch
