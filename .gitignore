# LiveCaptionTranslator .gitignore

# Visual Studio / Rider
.vs/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# .NET / WPF build output
[Bb]in/
[Oo]bj/
publish/
artifacts/
TestResults/
*.nupkg
*.snupkg
*.pdb

# Runtime logs and local diagnostics
logs/
**/logs/
*.log
*.dmp

# Python cache / virtual environments
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env
.env.*

# Local NLLB / model files
# Keep worker code, tokenizer metadata, and small CT2 metadata tracked.
# Do not commit large model weights; GitHub rejects normal blobs over 100MB.
tools/nllb/models/
tools/nllb/checkpoints/
tools/nllb/cache/
tools/nllb/*.bin
tools/nllb/*.pt
tools/nllb/*.pth
tools/nllb/*.safetensors
tools/nllb/*.onnx
tools/nllb/*.spm
tools/nllb/**/*.bin
tools/nllb/**/*.pt
tools/nllb/**/*.pth
tools/nllb/**/*.safetensors
tools/nllb/**/*.onnx
tools/nllb/**/*.spm
tools/nllb/**/.cache/
!tools/nllb/**/.gitkeep
!tools/nllb/**/*.json

# Local config and secrets
appsettings.Development.json
appsettings.Local.json
*.local.json
*.secret.json

# OS files
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
