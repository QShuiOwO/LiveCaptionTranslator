<Window x:Class="LiveCaptionTranslator.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="LiveCaptionTranslator Overlay"
        Width="900"
        Height="180"
        MinWidth="320"
        MinHeight="90"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid x:Name="OverlayRoot"
          Margin="8"
          MouseLeftButtonDown="OverlayRoot_MouseLeftButtonDown">
        <Border Background="#101010"
                CornerRadius="8"
                Opacity="{Binding BackgroundOpacity}" />

        <Grid Margin="18,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding SourceText}"
                       Visibility="{Binding ShowSourceText, Converter={StaticResource BooleanToVisibilityConverter}}"
                       FontSize="{Binding SourceFontSize}"
                       MaxHeight="{Binding SourceMaxHeight}"
                       Foreground="#D6D6D6"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="1"
                       Text="{Binding TranslatedText}"
                       FontSize="{Binding FontSize}"
                       MaxHeight="{Binding TranslatedMaxHeight}"
                       FontWeight="SemiBold"
                       Foreground="White"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />
        </Grid>

        <primitives:Thumb x:Name="ResizeThumb"
                          Width="18"
                          Height="18"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Cursor="SizeNWSE"
                          DragDelta="ResizeThumb_DragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                    <Border Background="#40FFFFFF"
                            CornerRadius="3" />
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
    </Grid>
</Window>
