<Window x:Class="LiveCaptionTranslator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LiveCaptionTranslator"
        Width="1180"
        Height="840"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#F6F7F9">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="105" />
            <RowDefinition Height="190" />
            <RowDefinition Height="160" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="LiveCaptionTranslator"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal"
                        Margin="0,12,0,0">
                <TextBlock Text="Live captions 状态："
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding LiveCaptionsStatus}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        Margin="0,6,0,0">
                <TextBlock Text="翻译状态："
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding TranslationStatus}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        Margin="0,6,0,0">
                <TextBlock Text="Overlay 状态："
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding OverlayStatus}" />
            </StackPanel>
        </StackPanel>

        <WrapPanel Grid.Row="1"
                   Margin="0,20,0,16">
            <Button Content="启动 Live captions"
                    MinWidth="140"
                    Padding="12,8"
                    Margin="0,0,12,0"
                    Click="StartLiveCaptionsButton_Click" />
            <Button Content="开始读取"
                    MinWidth="110"
                    Padding="12,8"
                    Margin="0,0,12,0"
                    Click="StartReadingButton_Click" />
            <Button Content="停止读取"
                    MinWidth="110"
                    Padding="12,8"
                    Margin="0,0,12,0"
                    Click="StopReadingButton_Click" />
            <Button Content="导出 UIA 树"
                    MinWidth="120"
                    Padding="12,8"
                    Margin="0,0,12,0"
                    Click="DumpUiaTreeButton_Click" />
            <Button Content="运行分段测试"
                    MinWidth="130"
                    Padding="12,8"
                    Margin="0,0,12,0"
                    Click="RunSegmentationDebugButton_Click" />
            <TextBlock Text="源语言"
                       VerticalAlignment="Center"
                       Margin="12,0,8,0" />
            <ComboBox ItemsSource="{Binding SourceLanguages}"
                      SelectedItem="{Binding SelectedSourceLanguage}"
                      MinWidth="110"
                      Padding="8,6"
                      Margin="0,0,12,0" />
            <TextBlock Text="目标语言"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox ItemsSource="{Binding TargetLanguages}"
                      SelectedItem="{Binding SelectedTargetLanguage}"
                      MinWidth="110"
                      Padding="8,6"
                      Margin="0,0,12,0" />
            <Button Content="启动翻译 worker"
                    MinWidth="140"
                    Padding="12,8"
                    Margin="0,0,12,0"
                    Click="StartTranslationWorkerButton_Click" />
            <Button Content="停止翻译 worker"
                    MinWidth="140"
                    Padding="12,8"
                    Margin="0,0,12,0"
                    Click="StopTranslationWorkerButton_Click" />
            <Button Content="显示 Overlay"
                    MinWidth="120"
                    Padding="12,8"
                    Margin="0,0,12,0"
                    Click="ShowOverlayButton_Click" />
            <Button Content="隐藏 Overlay"
                    MinWidth="120"
                    Padding="12,8"
                    Margin="0,0,12,0"
                    Click="HideOverlayButton_Click" />
            <CheckBox Content="锁定 Overlay"
                      IsChecked="{Binding OverlayIsLocked, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="8,0,12,0"
                      Checked="OverlayLockedCheckBox_Changed"
                      Unchecked="OverlayLockedCheckBox_Changed" />
            <CheckBox Content="鼠标穿透"
                      IsChecked="{Binding OverlayIsClickThrough, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="0,0,12,0"
                      Checked="OverlayClickThroughCheckBox_Changed"
                      Unchecked="OverlayClickThroughCheckBox_Changed" />
            <CheckBox Content="显示原文"
                      IsChecked="{Binding OverlayShowSourceText, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="0,0,12,0"
                      Checked="OverlayShowSourceCheckBox_Changed"
                      Unchecked="OverlayShowSourceCheckBox_Changed" />
            <TextBlock Text="字号"
                       VerticalAlignment="Center"
                       Margin="8,0,8,0" />
            <Slider Width="100"
                    Minimum="16"
                    Maximum="56"
                    AutoToolTipPlacement="TopLeft"
                    Value="{Binding OverlayFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ValueChanged="OverlayFontSizeSlider_ValueChanged" />
            <TextBlock Text="透明度"
                       VerticalAlignment="Center"
                       Margin="16,0,8,0" />
            <Slider Width="100"
                    Minimum="0.1"
                    Maximum="0.9"
                    AutoToolTipPlacement="TopLeft"
                    Value="{Binding OverlayBackgroundOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ValueChanged="OverlayOpacitySlider_ValueChanged" />
        </WrapPanel>

        <GroupBox Grid.Row="2"
                  Header="当前实时原文"
                  Padding="12">
            <TextBox Text="{Binding OriginalSubtitleText}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="White"
                     FontSize="16" />
        </GroupBox>

        <GroupBox Grid.Row="3"
                  Header="当前候选片段"
                  Padding="12"
                  Margin="0,16,0,0">
            <TextBox Text="{Binding CurrentBufferText, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="White"
                     FontSize="15" />
        </GroupBox>

        <Grid Grid.Row="4"
              Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0"
                      Header="已提交片段 final segments"
                      Padding="12">
                <ListBox x:Name="SubmittedSegmentsListBox"
                         ItemsSource="{Binding SubmittedSegments}"
                         BorderThickness="0"
                         Background="White"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding UpdatedAt, StringFormat={}{0:HH:mm:ss}}"
                                           Foreground="#666666" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Text}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <GroupBox Grid.Column="2"
                      Header="翻译结果"
                      Padding="12">
                <ListBox x:Name="TranslationResultsListBox"
                         ItemsSource="{Binding TranslationResults}"
                         BorderThickness="0"
                         Background="White"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding CompletedAt, StringFormat={}{0:HH:mm:ss}}"
                                               Foreground="#666666" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Status}"
                                               Foreground="#666666" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TranslatedText}"
                                               TextWrapping="Wrap" />
                                </Grid>
                                <TextBlock Text="{Binding SourceText}"
                                           Foreground="#666666"
                                           TextWrapping="Wrap"
                                           Margin="172,2,0,0" />
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="#A33A3A"
                                           TextWrapping="Wrap"
                                           Margin="172,2,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="5"
                  Header="日志"
                  Padding="12"
                  Margin="0,16,0,0">
            <TextBox x:Name="LogTextBox"
                     Text="{Binding LogText, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="White"
                     TextChanged="LogTextBox_TextChanged" />
        </GroupBox>
    </Grid>
</Window>
